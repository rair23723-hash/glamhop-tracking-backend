{% comment %}
  GlamHop Track Order Page
  Shopify App Proxy /apps/tracking
  AfterShip-matched layout | Live Shiprocket data | IST timezone-aware
{% endcomment %}

<div class="gh-wrap">
  <div class="gh-container">

    <!-- SEARCH SECTION -->
    <div id="gh-search-section">
      <div class="gh-header">
        <h1 class="gh-heading">Track your order</h1>
        <p class="gh-subhead">Enter your order details below for real-time shipping updates.</p>
      </div>

      <div class="gh-card gh-form-card">
        <div class="gh-tabs" role="tablist">
          <button class="gh-tab gh-tab--active" id="gh-tab-order" role="tab" type="button">Order Number</button>
          <button class="gh-tab" id="gh-tab-awb" role="tab" type="button">Tracking Number</button>
          <div class="gh-tab-bar" id="gh-tab-bar"></div>
        </div>

        <form id="gh-form" novalidate>
          <div id="gh-fields-order">
            <div class="gh-field">
              <label class="gh-label" for="gh-order-num">Order Number</label>
              <div class="gh-input-wrap">
                <span class="gh-prefix">#</span>
                <input class="gh-input" type="text" id="gh-order-num" placeholder="1003" autocomplete="off" />
              </div>
              <p class="gh-hint">Found in your confirmation email</p>
            </div>
            <div class="gh-field" style="margin-top:18px">
              <label class="gh-label" for="gh-email">Email Address</label>
              <div class="gh-input-wrap">
                <input class="gh-input gh-input--no-prefix" type="email" id="gh-email" placeholder="you@example.com" autocomplete="email" />
              </div>
              <p class="gh-hint">Use the email you ordered with</p>
            </div>
          </div>

          <div id="gh-fields-awb" hidden>
            <div class="gh-field">
              <label class="gh-label" for="gh-awb-input">Tracking Number (AWB)</label>
              <div class="gh-input-wrap">
                <input class="gh-input gh-input--no-prefix" type="text" id="gh-awb-input" placeholder="e.g. 370604336417" autocomplete="off" />
              </div>
              <p class="gh-hint">Your Air Waybill or shipment tracking code</p>
            </div>
          </div>

          <button class="gh-btn-submit" type="submit" id="gh-submit">
            <span class="gh-btn-label">Track Order</span>
            <span class="gh-btn-spinner" aria-hidden="true"></span>
          </button>
        </form>
      </div>

      <div class="gh-error" id="gh-error" role="alert" hidden>
        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span id="gh-error-msg"></span>
      </div>
    </div>

    <!-- SKELETON LOADER -->
    <div id="gh-skeleton" hidden>
      <div class="gh-card">
        <div class="sk-line sk-short sh"></div>
        <div class="sk-line sk-tall sh" style="margin:10px 0 14px"></div>
        <div class="sk-line sk-medium sh"></div>
        <div class="sk-progress sh"></div>
      </div>
      <div class="gh-card">
        <div class="sk-line sk-short sh" style="margin-bottom:20px"></div>
        <div class="sk-row">
          <div class="sk-dot sh"></div>
          <div style="flex:1">
            <div class="sk-line sk-medium sh"></div>
            <div class="sk-line sk-short sh" style="margin-top:6px"></div>
          </div>
        </div>
        <div class="sk-row" style="margin-top:18px">
          <div class="sk-dot sh"></div>
          <div style="flex:1">
            <div class="sk-line sk-medium sh"></div>
            <div class="sk-line sk-short sh" style="margin-top:6px"></div>
          </div>
        </div>
        <div class="sk-row" style="margin-top:18px">
          <div class="sk-dot sh"></div>
          <div style="flex:1">
            <div class="sk-line sk-medium sh"></div>
            <div class="sk-line sk-short sh" style="margin-top:6px"></div>
          </div>
        </div>
      </div>
      <div class="gh-card">
        <div style="display:flex;gap:20px">
          <div style="flex:1">
            <div class="sk-line sk-short sh"></div>
            <div class="sk-line sk-medium sh" style="margin-top:6px"></div>
          </div>
          <div style="flex:1">
            <div class="sk-line sk-short sh"></div>
            <div class="sk-line sk-medium sh" style="margin-top:6px"></div>
          </div>
        </div>
      </div>
    </div>

    <!-- RESULT VIEW -->
    <div id="gh-result" hidden>

      <button class="gh-back" id="gh-back">
        <svg width="13" height="13" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
        </svg>
        Back to search
      </button>

      <!-- Hero / EDD card -->
      <div class="gh-card gh-hero-card">
        <div class="gh-hero-top">
          <div class="gh-hero-left">
            <p class="gh-edd-label">Estimated delivery</p>
            <h2 class="gh-edd-value" id="gh-edd">—</h2>
          </div>
          <div class="gh-hero-badge" id="gh-status-badge"></div>
        </div>

        <p class="gh-status-line" id="gh-status-line">—</p>

        <!-- 6-stage progress bar -->
        <div class="gh-progress-wrap">
          <div class="gh-progress-track">
            <div class="gh-progress-fill" id="gh-progress-fill"></div>
          </div>
          <div class="gh-progress-steps">
            <div class="gh-step" data-step="0">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">To be<br>processed</span>
            </div>
            <div class="gh-step" data-step="1">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">Prepared</span>
            </div>
            <div class="gh-step" data-step="2">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">Shipping<br>soon</span>
            </div>
            <div class="gh-step" data-step="3">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">In transit</span>
            </div>
            <div class="gh-step" data-step="4">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">Out for<br>delivery</span>
            </div>
            <div class="gh-step" data-step="5">
              <div class="gh-step-dot"></div>
              <span class="gh-step-lbl">Delivered</span>
            </div>
          </div>
        </div>

        <!-- Timezone selector (AfterShip-style inline row) -->
        <div class="gh-tz-row">
          <span class="gh-tz-label">Checkpoint timezone</span>
          <div class="gh-tz-wrap">
            <select class="gh-tz-select" id="gh-tz">
              <option value="local">Local Time</option>
              <option value="origin" selected>Origin Time (IST)</option>
              <option value="destination">Destination Time (IST)</option>
            </select>
            <svg class="gh-tz-caret" width="10" height="10" viewBox="0 0 10 10" fill="currentColor">
              <path d="M5 7L1 3h8z"/>
            </svg>
          </div>
        </div>
      </div>

      <!-- Timeline card -->
      <div class="gh-card">
        <h3 class="gh-section-title">Shipment updates</h3>
        <div class="gh-timeline" id="gh-timeline"></div>
      </div>

      <!-- Carrier / tracking number card -->
      <div class="gh-card gh-carrier-card">
        <div class="gh-carrier-header">
          <div class="gh-carrier-logo">
            <svg width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 17a2 2 0 11-4 0 2 2 0 014 0zM19 17a2 2 0 11-4 0 2 2 0 014 0z"/>
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 16V6a1 1 0 00-1-1H4a1 1 0 00-1 1v10a1 1 0 001 1h1m8-1a1 1 0 01-1 1H9m4-1V8a1 1 0 011-1h2.586a1 1 0 01.707.293l3.414 3.414a1 1 0 01.293.707V16a1 1 0 01-1 1h-1m-6-1a1 1 0 001 1h1M5 17a2 2 0 104 0m-4 0a2 2 0 114 0m6 0a2 2 0 104 0m-4 0a2 2 0 114 0"/>
            </svg>
          </div>
          <div>
            <p class="gh-carrier-sublabel">Carrier</p>
            <p class="gh-carrier-name" id="gh-carrier-name">—</p>
          </div>
        </div>
        <div class="gh-carrier-grid">
          <div class="gh-carrier-cell">
            <p class="gh-carrier-sublabel">Tracking number</p>
            <div class="gh-copy-row">
              <span class="gh-carrier-val gh-mono" id="gh-awb-val">—</span>
              <button class="gh-copy-btn" id="gh-copy-btn" title="Copy tracking number">
                <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                </svg>
                <span class="gh-copy-tip" id="gh-copy-tip">Copied!</span>
              </button>
            </div>
          </div>
          <div class="gh-carrier-cell">
            <p class="gh-carrier-sublabel">Order number</p>
            <p class="gh-carrier-val" id="gh-order-val">—</p>
          </div>
        </div>
      </div>

    </div><!-- /gh-result -->
  </div><!-- /gh-container -->
</div><!-- /gh-wrap -->

<style>
*,*::before,*::after{box-sizing:border-box}
.gh-wrap{width:100%;min-height:100vh;padding:52px 16px 100px;background:#f5f5f5;font-family:-apple-system,BlinkMacSystemFont,"Inter","Segoe UI",Helvetica,Arial,sans-serif;color:#1a1a1a;-webkit-font-smoothing:antialiased}
.gh-container{max-width:620px;margin:0 auto}

/* Header */
.gh-header{text-align:center;margin-bottom:32px}
.gh-heading{font-size:clamp(1.35rem,4vw,1.8rem);font-weight:700;letter-spacing:-.02em;margin:0 0 8px;color:#111}
.gh-subhead{font-size:.875rem;color:#666;margin:0;line-height:1.5}

/* Card */
.gh-card{background:#fff;border:1px solid #e4e4e4;border-radius:10px;padding:24px;margin-bottom:16px}
.gh-form-card{padding-top:0}

/* Tabs */
.gh-tabs{display:flex;position:relative;border-bottom:1px solid #ebebeb;margin-bottom:24px}
.gh-tab{padding:14px 16px;background:none;border:none;font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:.07em;color:#999;cursor:pointer;transition:color .2s}
.gh-tab--active{color:#111}
.gh-tab-bar{position:absolute;bottom:-1px;height:2px;background:#111;border-radius:1px;transition:left .25s cubic-bezier(.4,0,.2,1),width .25s cubic-bezier(.4,0,.2,1)}

/* Fields */
.gh-field{display:flex;flex-direction:column;gap:6px}
.gh-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#444}
.gh-input-wrap{position:relative}
.gh-prefix{position:absolute;left:13px;top:50%;transform:translateY(-50%);font-size:1rem;color:#aaa;pointer-events:none}
.gh-input{width:100%;padding:13px 14px 13px 28px;font-size:.95rem;border:1.5px solid #ccc;border-radius:6px;outline:none;color:#111;background:#fff;transition:border-color .2s;-webkit-appearance:none}
.gh-input--no-prefix{padding-left:14px}
.gh-input:focus{border-color:#111}
.gh-hint{font-size:.75rem;color:#999;margin:0}

/* Submit button */
.gh-btn-submit{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;margin-top:24px;padding:15px;background:#111;color:#fff;font-size:.85rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;border:none;border-radius:6px;cursor:pointer;transition:background .2s}
.gh-btn-submit:hover{background:#333}
.gh-btn-submit:disabled{background:#ccc;cursor:not-allowed}
.gh-btn-spinner{display:none;width:15px;height:15px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:gh-spin .6s linear infinite}
.gh-btn-submit.loading .gh-btn-label{display:none}
.gh-btn-submit.loading .gh-btn-spinner{display:block}
@keyframes gh-spin{to{transform:rotate(360deg)}}

/* Error */
.gh-error{display:none}
.gh-error:not([hidden]){display:flex;align-items:flex-start;gap:10px;padding:13px 16px;background:#fff8f8;border:1px solid #fecdd3;border-radius:6px;color:#be123c;font-size:.875rem;margin-top:14px}

/* Back */
.gh-back{display:inline-flex;align-items:center;gap:6px;background:none;border:none;padding:0;margin-bottom:18px;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#888;cursor:pointer;transition:color .2s}
.gh-back:hover{color:#111}

/* Hero */
.gh-hero-card{padding:28px 24px 22px}
.gh-hero-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:14px}
.gh-hero-left{flex:1}
.gh-edd-label{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.08em;color:#888;margin:0 0 6px}
.gh-edd-value{font-size:clamp(1.6rem,5vw,2.2rem);font-weight:800;letter-spacing:-.025em;color:#111;margin:0;line-height:1.15}
.gh-edd-value .edd-line{display:block}
.gh-edd-value .edd-time{display:block;font-size:.95rem;font-weight:400;color:#555;margin-top:4px}
.gh-hero-badge{flex-shrink:0;padding:4px 10px;border-radius:20px;font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;margin-left:14px;margin-top:4px;background:#eff6ff;color:#1d4ed8;border:1px solid #bfdbfe}
.gh-hero-badge.delivered{background:#f0fdf4;color:#15803d;border-color:#bbf7d0}
.gh-hero-badge.ofd{background:#fff7ed;color:#c2410c;border-color:#fed7aa}
.gh-hero-badge.exception{background:#fef2f2;color:#b91c1c;border-color:#fecaca}
.gh-hero-badge.pending{background:#f9fafb;color:#4b5563;border-color:#e5e7eb}
.gh-status-line{font-size:1.05rem;font-weight:700;color:#111;margin:0 0 26px}

/* Progress bar */
.gh-progress-wrap{position:relative;padding:0 0 26px}
.gh-progress-track{position:absolute;top:5px;left:calc(100%/12);right:calc(100%/12);height:3px;background:#e9e9e9;border-radius:2px;z-index:1}
.gh-progress-fill{height:100%;width:0%;background:#111;border-radius:2px;transition:width 1s cubic-bezier(.4,0,.2,1)}
.gh-progress-steps{display:flex;justify-content:space-between;position:relative;z-index:2}
.gh-step{display:flex;flex-direction:column;align-items:center;width:16.666%}
.gh-step-dot{width:12px;height:12px;border-radius:50%;background:#fff;border:2px solid #ddd;box-shadow:0 0 0 3px #fff;margin-bottom:10px;transition:border-color .3s,background .3s}
.gh-step.done .gh-step-dot{background:#111;border-color:#111}
.gh-step.curr .gh-step-dot{background:#fff;border-color:#111;border-width:3px;animation:gh-pulse 2s infinite}
.gh-step-lbl{font-size:.6rem;text-align:center;color:#bbb;line-height:1.25;transition:color .3s}
.gh-step.done .gh-step-lbl,.gh-step.curr .gh-step-lbl{color:#333}
@keyframes gh-pulse{0%,100%{box-shadow:0 0 0 0 rgba(17,17,17,.15)}50%{box-shadow:0 0 0 5px rgba(17,17,17,0)}}

/* Timezone row */
.gh-tz-row{display:flex;align-items:center;gap:8px;padding-top:16px;border-top:1px solid #f0f0f0;font-size:.78rem;color:#888}
.gh-tz-label{font-weight:500}
.gh-tz-wrap{position:relative;display:flex;align-items:center}
.gh-tz-select{appearance:none;-webkit-appearance:none;background:none;border:none;outline:none;font-size:.78rem;font-weight:700;color:#111;cursor:pointer;padding-right:16px}
.gh-tz-caret{position:absolute;right:0;pointer-events:none;color:#555}

/* Timeline */
.gh-section-title{font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:.09em;color:#888;margin:0 0 22px}
.gh-timeline{position:relative}
.gh-tl-item{display:grid;grid-template-columns:72px 26px 1fr;position:relative;padding-bottom:22px}
.gh-tl-item:last-child{padding-bottom:0}
.gh-tl-item::before{content:'';position:absolute;left:85px;top:18px;bottom:0;width:1px;background:#e4e4e4}
.gh-tl-item:last-child::before{display:none}
.gh-tl-time{text-align:right;padding-top:2px}
.gh-tl-date{font-size:.78rem;font-weight:700;color:#222}
.gh-tl-hour{font-size:.7rem;color:#888;margin-top:2px}
.gh-tl-dot-col{display:flex;justify-content:center;padding-top:4px}
.gh-tl-dot{width:8px;height:8px;border-radius:50%;border:2px solid #ccc;background:#fff;flex-shrink:0}
.gh-tl-item:first-child .gh-tl-dot{border-color:#111;background:#111}
.gh-tl-body{padding-left:6px}
.gh-tl-title{font-size:.875rem;font-weight:700;color:#111;margin-bottom:3px}
.gh-tl-desc{font-size:.8rem;color:#555;line-height:1.45}
.gh-tl-loc{font-size:.75rem;color:#888;margin-top:3px}
.gh-tl-tag{display:inline-block;font-size:.65rem;font-weight:600;text-transform:uppercase;background:#f3f4f6;color:#555;padding:2px 6px;border-radius:3px;margin-top:6px;letter-spacing:.04em}

/* Carrier card */
.gh-carrier-card{padding:20px 24px}
.gh-carrier-header{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid #f0f0f0}
.gh-carrier-logo{width:38px;height:38px;border-radius:50%;border:1px solid #e4e4e4;background:#fafafa;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:#444}
.gh-carrier-name{font-size:.9rem;font-weight:700;color:#111;margin:0}
.gh-carrier-sublabel{font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.07em;color:#aaa;margin:0 0 3px}
.gh-carrier-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.gh-carrier-cell{display:flex;flex-direction:column;gap:2px}
.gh-carrier-val{font-size:.875rem;font-weight:600;color:#111}
.gh-mono{font-family:"SF Mono","Fira Mono","Courier New",monospace;letter-spacing:.03em}
.gh-copy-row{display:flex;align-items:center;gap:8px}
.gh-copy-btn{position:relative;background:none;border:none;padding:4px;color:#aaa;cursor:pointer;border-radius:4px;transition:color .2s,background .2s}
.gh-copy-btn:hover{color:#111;background:#f5f5f5}
.gh-copy-tip{position:absolute;bottom:calc(100% + 5px);left:50%;transform:translateX(-50%);background:#111;color:#fff;font-size:.65rem;font-weight:600;padding:3px 7px;border-radius:3px;white-space:nowrap;opacity:0;pointer-events:none;transition:opacity .2s}
.gh-copy-btn.copied .gh-copy-tip{opacity:1}

/* Skeleton shimmer */
.sh{background:linear-gradient(90deg,#efefef 25%,#f8f8f8 50%,#efefef 75%);background-size:200% 100%;animation:gh-shim 1.4s infinite;border-radius:4px}
@keyframes gh-shim{0%{background-position:200% 0}100%{background-position:-200% 0}}
.sk-line{height:11px}.sk-short{width:32%}.sk-medium{width:60%}.sk-tall{width:80%;height:22px}.sk-progress{height:3px;margin:24px 0 10px}.sk-row{display:flex;gap:12px;align-items:flex-start}.sk-dot{width:10px;height:10px;border-radius:50%;flex-shrink:0;margin-top:3px}

/* Fade in result */
@keyframes gh-fadein{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
#gh-result{animation:gh-fadein .35s ease}

/* Mobile */
@media(max-width:480px){
  .gh-wrap{padding:36px 12px 80px}
  .gh-card{padding:18px}
  .gh-hero-card{padding:20px 18px 18px}
  .gh-step-lbl{font-size:.55rem}
  .gh-carrier-grid{grid-template-columns:1fr}
  .gh-tl-item{grid-template-columns:62px 22px 1fr}
  .gh-tl-item::before{left:74px}
}
</style>

<script>
(function () {
  'use strict';

  /* DOM refs */
  var searchSection = document.getElementById('gh-search-section');
  var skeletonEl    = document.getElementById('gh-skeleton');
  var resultEl      = document.getElementById('gh-result');
  var errorEl       = document.getElementById('gh-error');
  var errorMsg      = document.getElementById('gh-error-msg');
  var form          = document.getElementById('gh-form');
  var submitBtn     = document.getElementById('gh-submit');
  var backBtn       = document.getElementById('gh-back');

  var tabOrder      = document.getElementById('gh-tab-order');
  var tabAwb        = document.getElementById('gh-tab-awb');
  var tabBar        = document.getElementById('gh-tab-bar');
  var fieldsOrder   = document.getElementById('gh-fields-order');
  var fieldsAwb     = document.getElementById('gh-fields-awb');

  var eddEl         = document.getElementById('gh-edd');
  var statusLineEl  = document.getElementById('gh-status-line');
  var statusBadge   = document.getElementById('gh-status-badge');
  var progressFill  = document.getElementById('gh-progress-fill');
  var progressSteps = document.querySelectorAll('.gh-step');
  var tzSelect      = document.getElementById('gh-tz');
  var timelineEl    = document.getElementById('gh-timeline');
  var carrierNameEl = document.getElementById('gh-carrier-name');
  var awbValEl      = document.getElementById('gh-awb-val');
  var orderValEl    = document.getElementById('gh-order-val');
  var copyBtn       = document.getElementById('gh-copy-btn');

  var activeTab = 'order';
  var lastData  = null;

  /* ── Tabs ── */
  function positionTabBar() {
    var btn = activeTab === 'order' ? tabOrder : tabAwb;
    tabBar.style.left  = btn.offsetLeft + 'px';
    tabBar.style.width = btn.offsetWidth + 'px';
  }
  setTimeout(positionTabBar, 80);
  window.addEventListener('resize', positionTabBar);

  tabOrder.addEventListener('click', function () {
    if (activeTab === 'order') return;
    activeTab = 'order';
    tabOrder.classList.add('gh-tab--active');
    tabAwb.classList.remove('gh-tab--active');
    fieldsOrder.hidden = false;
    fieldsAwb.hidden   = true;
    positionTabBar();
    hideError();
  });

  tabAwb.addEventListener('click', function () {
    if (activeTab === 'awb') return;
    activeTab = 'awb';
    tabAwb.classList.add('gh-tab--active');
    tabOrder.classList.remove('gh-tab--active');
    fieldsOrder.hidden = true;
    fieldsAwb.hidden   = false;
    positionTabBar();
    hideError();
  });

  /* ── Helpers ── */
  function showError(msg) {
    errorMsg.textContent = msg;
    errorEl.hidden       = false;
    skeletonEl.hidden    = true;
    resultEl.hidden      = true;
    searchSection.hidden = false;
  }
  function hideError() { errorEl.hidden = true; }

  function setLoading(on) {
    submitBtn.disabled = on;
    submitBtn.classList.toggle('loading', on);
  }

  function showResults() {
    searchSection.hidden = true;
    skeletonEl.hidden    = true;
    resultEl.hidden      = false;
  }
  function showSearch() {
    searchSection.hidden = false;
    skeletonEl.hidden    = true;
    resultEl.hidden      = true;
  }
  function showSkeleton() {
    searchSection.hidden = true;
    skeletonEl.hidden    = false;
    resultEl.hidden      = true;
  }

  /* ── Date / timezone helpers ── */
  /*
   * Shiprocket timestamps arrive with +05:30 already appended by our backend
   * (e.g. "2026-07-07T05:24:38+05:30"), so new Date() gives the correct UTC
   * moment and we can re-format to any IANA timezone.
   */
  function fmtDatetime(iso, tz) {
    if (!iso) return { date: '—', time: '—' };
    try {
      var d = new Date(iso);
      if (isNaN(d)) return { date: iso, time: '' };
      var opts = (tz && tz !== 'local') ? { timeZone: tz } : {};
      var date = d.toLocaleDateString('en-IN', Object.assign({ day: 'numeric', month: 'short' }, opts));
      var time = d.toLocaleTimeString('en-IN', Object.assign({ hour: '2-digit', minute: '2-digit', hour12: true }, opts)).toUpperCase();
      return { date: date, time: time };
    } catch (e) {
      return { date: iso, time: '' };
    }
  }

  function tzFromMode(mode, originTz) {
    if (mode === 'origin' || mode === 'destination') return originTz || 'Asia/Kolkata';
    return null; /* local */
  }

  /* ── EDD formatter ── */
  function formatEDD(eddStr) {
    if (!eddStr) return '<span class="edd-line">Unavailable</span>';
    try {
      var d = new Date(eddStr);
      if (isNaN(d)) return '<span class="edd-line">' + eddStr + '</span>';
      var today    = new Date();
      var tomorrow = new Date(); tomorrow.setDate(today.getDate() + 1);
      if (d.toDateString() === today.toDateString()) {
        var t = d.toLocaleTimeString('en-IN', { hour: '2-digit', minute: '2-digit', hour12: true }).toUpperCase();
        return '<span class="edd-line">Today</span><span class="edd-time">at ' + t + '</span>';
      }
      if (d.toDateString() === tomorrow.toDateString()) {
        return '<span class="edd-line">Tomorrow</span>';
      }
      return '<span class="edd-line">' + d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) + '</span>';
    } catch (e) {
      return '<span class="edd-line">' + eddStr + '</span>';
    }
  }

  /* ── Status helpers ── */
  var STATUS_MAP = {
    'DELIVERED':                    'Delivered',
    'OUT FOR DELIVERY':             'Out for delivery',
    'IN TRANSIT':                   'In transit',
    'PICKUP DONE':                  'Picked up',
    'READY FOR RECEIVE':            'Shipping soon',
    'ARRIVED AT CARRIER FACILITY':  'Arrived at facility',
    'DEPARTED':                     'In transit',
    'PENDING':                      'To be processed',
    'CONFIRMED':                    'Order confirmed',
    'NOT YET SHIPPED':              'To be processed',
    'CANCELLED':                    'Cancelled'
  };

  function friendlyStatus(raw) {
    if (!raw) return 'Update';
    return STATUS_MAP[raw.trim().toUpperCase()] || raw;
  }

  function setProgress(status) {
    var s = (status || '').toLowerCase().replace(/\s+/g, '');
    var idx = 0;
    if (s.indexOf('delivered') !== -1)                                    idx = 5;
    else if (s.indexOf('out') !== -1 || s.indexOf('outfordelivery') !== -1) idx = 4;
    else if (s.indexOf('transit') !== -1 || s.indexOf('depart') !== -1 ||
             s.indexOf('pickup') !== -1 || s.indexOf('arrived') !== -1)   idx = 3;
    else if (s.indexOf('shippingsoon') !== -1 || s.indexOf('shipped') !== -1 ||
             s.indexOf('readyforreceive') !== -1 || s.indexOf('dispatch') !== -1) idx = 2;
    else if (s.indexOf('pack') !== -1 || s.indexOf('prepar') !== -1 ||
             s.indexOf('process') !== -1)                                  idx = 1;

    progressFill.style.width = (idx / 5 * 100) + '%';
    progressSteps.forEach(function (step, i) {
      step.classList.remove('done', 'curr');
      if (i < idx)  step.classList.add('done');
      if (i === idx) step.classList.add('curr');
    });
  }

  function setStatusBadge(status) {
    var s   = (status || '').toLowerCase();
    var cls = 'transit', label = 'In transit';
    if (s.indexOf('delivered') !== -1)              { cls = 'delivered'; label = 'Delivered'; }
    else if (s.indexOf('out') !== -1)               { cls = 'ofd';       label = 'Out for delivery'; }
    else if (s.indexOf('cancel') !== -1)            { cls = 'exception'; label = 'Cancelled'; }
    else if (s.indexOf('exception') !== -1)         { cls = 'exception'; label = 'Exception'; }
    else if (s.indexOf('pending') !== -1 ||
             s.indexOf('not yet') !== -1)           { cls = 'pending';   label = 'Pending'; }
    statusBadge.className   = 'gh-hero-badge ' + cls;
    statusBadge.textContent = label;
  }

  function getStatusHeadline(status) {
    var s = (status || '').toLowerCase();
    if (s.indexOf('delivered') !== -1)  return 'Delivered';
    if (s.indexOf('out') !== -1)        return 'Out for delivery';
    if (s.indexOf('cancel') !== -1)     return 'Shipment cancelled';
    if (s.indexOf('exception') !== -1)  return 'Delivery exception';
    if (s.indexOf('pending') !== -1 ||
        s.indexOf('not yet') !== -1)    return 'Order received \u2014 not yet shipped';
    return 'Your order is on the way';
  }

  /* ── Timeline renderer ── */
  function renderTimeline(events, courier, originTz, mode) {
    if (!events || events.length === 0) {
      timelineEl.innerHTML = '<p style="font-size:.85rem;color:#888;margin:0">No checkpoint data yet. Check back once the shipment is in transit.</p>';
      return;
    }
    var tz = tzFromMode(mode, originTz);
    timelineEl.innerHTML = events.map(function (ev) {
      var dt    = fmtDatetime(ev.date, tz);
      var title = friendlyStatus(ev.status);
      var desc  = ev.description || '';
      var showDesc = desc && desc.toLowerCase() !== title.toLowerCase();

      /* Build location: prefer separate city/state/country, fall back to raw location string */
      var parts = [];
      if (ev.city)    parts.push(ev.city);
      if (ev.state)   parts.push(ev.state);
      if (ev.country) parts.push(ev.country);
      var loc = parts.length ? parts.join(', ') : (ev.location || '');

      return (
        '<div class="gh-tl-item">' +
          '<div class="gh-tl-time">' +
            '<div class="gh-tl-date">' + dt.date + '</div>' +
            '<div class="gh-tl-hour">' + dt.time + '</div>' +
          '</div>' +
          '<div class="gh-tl-dot-col"><div class="gh-tl-dot"></div></div>' +
          '<div class="gh-tl-body">' +
            '<div class="gh-tl-title">' + title + '</div>' +
            (showDesc ? '<div class="gh-tl-desc">' + desc + '</div>' : '') +
            (loc      ? '<div class="gh-tl-loc">'  + loc  + '</div>' : '') +
            (courier  ? '<span class="gh-tl-tag">'  + courier + '</span>' : '') +
          '</div>' +
        '</div>'
      );
    }).join('');
  }

  /* ── Populate result ── */
  function populateResult(data) {
    lastData = data;
    var order    = data.order    || {};
    var tracking = data.tracking || {};
    var events   = tracking.events || [];
    var originTz = tracking.origin_timezone || 'Asia/Kolkata';

    /* Use latest event status as the live status if available */
    var liveStatus = events.length ? events[0].status : (order.status || '');

    eddEl.innerHTML       = formatEDD(tracking.estimated_delivery);
    statusLineEl.textContent = getStatusHeadline(liveStatus);
    setStatusBadge(liveStatus);
    setProgress(liveStatus);

    /* Default to Origin (IST) to match Shiprocket's native timezone */
    tzSelect.value = 'origin';
    renderTimeline(events, tracking.courier, originTz, 'origin');

    carrierNameEl.textContent = tracking.courier || 'Shiprocket';
    awbValEl.textContent      = tracking.awb      || '—';
    orderValEl.textContent    = order.number       || '—';
  }

  /* ── Timezone selector ── */
  tzSelect.addEventListener('change', function () {
    if (!lastData) return;
    var tracking = lastData.tracking || {};
    renderTimeline(
      tracking.events || [],
      tracking.courier,
      tracking.origin_timezone || 'Asia/Kolkata',
      tzSelect.value
    );
  });

  /* ── Copy AWB ── */
  copyBtn.addEventListener('click', function () {
    var val = awbValEl.textContent;
    if (!val || val === '—') return;
    navigator.clipboard.writeText(val).then(function () {
      copyBtn.classList.add('copied');
      setTimeout(function () { copyBtn.classList.remove('copied'); }, 2200);
    });
  });

  /* ── Back ── */
  backBtn.addEventListener('click', function () {
    window.history.pushState(null, '', window.location.pathname);
    showSearch();
    hideError();
  });

  /* ── Form submit ── */
  form.addEventListener('submit', function (e) {
    e.preventDefault();
    hideError();

    var params = {};
    if (activeTab === 'order') {
      var num   = document.getElementById('gh-order-num').value.trim();
      var email = document.getElementById('gh-email').value.trim();
      if (!num)   return showError('Please enter your order number.');
      if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email))
        return showError('Please enter a valid email address.');
      params = { order_number: num, email: email };
    } else {
      var awb = document.getElementById('gh-awb-input').value.trim();
      if (!awb) return showError('Please enter your tracking number.');
      params = { awb: awb };
    }

    setLoading(true);
    showSkeleton();

    var qs = new URLSearchParams(params).toString();
    fetch('/apps/tracking/track?' + qs, { headers: { Accept: 'application/json' } })
      .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, data: d }; }); })
      .then(function (r) {
        setLoading(false);
        if (!r.ok || !r.data.success) {
          showSearch();
          showError(r.data.error || 'Tracking details are temporarily unavailable. Please try again.');
          window.history.replaceState(null, '', window.location.pathname);
          return;
        }
        populateResult(r.data);
        showResults();
        window.history.pushState(null, '', '?' + qs);
      })
      .catch(function () {
        setLoading(false);
        showSearch();
        showError('Tracking details are temporarily unavailable. Please try again.');
        window.history.replaceState(null, '', window.location.pathname);
      });
  });

  /* ── On page load: handle URL params ── */
  function handlePageLoad() {
    var sp    = new URLSearchParams(window.location.search);
    var awb   = sp.get('awb');
    var num   = sp.get('order_number');
    var email = sp.get('email');

    if (!awb && (!num || !email)) { showSearch(); return; }

    showSkeleton();
    var params = awb ? { awb: awb } : { order_number: num, email: email };

    if (awb) {
      activeTab = 'awb';
      tabAwb.classList.add('gh-tab--active');
      tabOrder.classList.remove('gh-tab--active');
      fieldsOrder.hidden = true;
      fieldsAwb.hidden   = false;
      document.getElementById('gh-awb-input').value = awb;
      setTimeout(positionTabBar, 50);
    } else {
      document.getElementById('gh-order-num').value = num;
      document.getElementById('gh-email').value      = email;
    }

    var qs = new URLSearchParams(params).toString();
    fetch('/apps/tracking/track?' + qs, { headers: { Accept: 'application/json' } })
      .then(function (res) { return res.json().then(function (d) { return { ok: res.ok, data: d }; }); })
      .then(function (r) {
        if (!r.ok || !r.data.success) {
          showSearch();
          showError(r.data.error || 'Tracking details are temporarily unavailable. Please try again.');
          return;
        }
        populateResult(r.data);
        showResults();
      })
      .catch(function () {
        showSearch();
        showError('Tracking details are temporarily unavailable. Please try again.');
      });
  }

  window.addEventListener('popstate', function () {
    var sp = new URLSearchParams(window.location.search);
    if (!sp.get('awb') && (!sp.get('order_number') || !sp.get('email'))) showSearch();
  });

  handlePageLoad();
})();
</script>