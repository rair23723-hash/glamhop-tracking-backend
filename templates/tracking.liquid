{% comment %}
  GlamHop — Track Order Page
  Served via Shopify App Proxy → rendered inside Fabric theme
  Mobile responsive, Fabric-compatible
{% endcomment %}

<div class="glamhop-tracking-wrapper">

  <div class="glamhop-tracking-container">

    <div class="glamhop-tracking-header">
      <h1 class="glamhop-tracking-title">Track Your Order</h1>
      <p class="glamhop-tracking-subtitle">Enter your order number and email address to see live tracking updates.</p>
    </div>

    <!-- Tracking Form -->
    <form class="glamhop-tracking-form" id="glamhop-track-form" novalidate>

      <div class="glamhop-field-group">
        <label class="glamhop-label" for="glamhop-order-number">Order Number</label>
        <input
          class="glamhop-input"
          type="text"
          id="glamhop-order-number"
          name="order_number"
          placeholder="#1001"
          autocomplete="off"
          required
        />
        <span class="glamhop-field-hint">Found in your order confirmation email</span>
      </div>

      <div class="glamhop-field-group">
        <label class="glamhop-label" for="glamhop-email">Email Address</label>
        <input
          class="glamhop-input"
          type="email"
          id="glamhop-email"
          name="email"
          placeholder="you@example.com"
          autocomplete="email"
          required
        />
        <span class="glamhop-field-hint">Use the email you placed the order with</span>
      </div>

      <button class="glamhop-btn" type="submit" id="glamhop-submit-btn">
        <span class="glamhop-btn-text">Track Order</span>
        <span class="glamhop-btn-loader" aria-hidden="true"></span>
      </button>

    </form>

    <!-- Error State -->
    <div class="glamhop-error" id="glamhop-error" role="alert" aria-live="polite" hidden>
      <svg class="glamhop-error-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
      </svg>
      <span id="glamhop-error-message"></span>
    </div>

    <!-- Tracking Result -->
    <div class="glamhop-result" id="glamhop-result" hidden>

      <!-- Order Summary -->
      <div class="glamhop-order-summary" id="glamhop-order-summary"></div>

      <!-- Timeline -->
      <div class="glamhop-timeline-section">
        <h2 class="glamhop-timeline-heading">Shipment Timeline</h2>
        <div class="glamhop-timeline" id="glamhop-timeline"></div>
      </div>

    </div>

  </div>

</div>

<style>
  .glamhop-tracking-wrapper {
    width: 100%;
    padding: 40px 16px 80px;
    box-sizing: border-box;
    font-family: var(--font-body-family, sans-serif);
    color: var(--color-foreground, #1a1a1a);
  }

  .glamhop-tracking-container {
    max-width: 600px;
    margin: 0 auto;
  }

  .glamhop-tracking-header {
    text-align: center;
    margin-bottom: 36px;
  }

  .glamhop-tracking-title {
    font-size: clamp(1.5rem, 4vw, 2rem);
    font-weight: 700;
    margin: 0 0 10px;
    letter-spacing: -0.02em;
  }

  .glamhop-tracking-subtitle {
    font-size: 0.95rem;
    color: var(--color-foreground-secondary, #666);
    margin: 0;
    line-height: 1.5;
  }

  .glamhop-tracking-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 24px;
  }

  .glamhop-field-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .glamhop-label {
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .glamhop-input {
    width: 100%;
    padding: 12px 16px;
    font-size: 1rem;
    border: 1.5px solid var(--color-border, #d1d1d1);
    border-radius: 8px;
    background: var(--color-background, #fff);
    color: var(--color-foreground, #1a1a1a);
    box-sizing: border-box;
    transition: border-color 0.2s ease;
    outline: none;
    -webkit-appearance: none;
  }

  .glamhop-input:focus {
    border-color: var(--color-foreground, #1a1a1a);
  }

  .glamhop-input.glamhop-input--error {
    border-color: #e53e3e;
  }

  .glamhop-field-hint {
    font-size: 0.78rem;
    color: var(--color-foreground-secondary, #888);
  }

  .glamhop-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 24px;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    background: var(--color-foreground, #1a1a1a);
    color: var(--color-background, #fff);
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    -webkit-appearance: none;
  }

  .glamhop-btn:hover {
    opacity: 0.85;
  }

  .glamhop-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .glamhop-btn-loader {
    display: none;
    width: 16px;
    height: 16px;
    border: 2px solid rgba(255,255,255,0.4);
    border-top-color: #fff;
    border-radius: 50%;
    animation: glamhop-spin 0.7s linear infinite;
  }

  .glamhop-btn.glamhop-btn--loading .glamhop-btn-loader {
    display: block;
  }

  .glamhop-btn.glamhop-btn--loading .glamhop-btn-text {
    opacity: 0.7;
  }

  @keyframes glamhop-spin {
    to { transform: rotate(360deg); }
  }

  /* Error */
  .glamhop-error {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 14px 16px;
    background: #fff5f5;
    border: 1px solid #fed7d7;
    border-radius: 8px;
    color: #c53030;
    font-size: 0.9rem;
    margin-bottom: 24px;
  }

  .glamhop-error-icon {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Order Summary */
  .glamhop-order-summary {
    background: var(--color-background-secondary, #f7f7f7);
    border-radius: 10px;
    padding: 20px;
    margin-bottom: 28px;
    font-size: 0.9rem;
    line-height: 1.7;
  }

  .glamhop-order-summary strong {
    font-weight: 600;
  }

  /* Timeline */
  .glamhop-timeline-heading {
    font-size: 1rem;
    font-weight: 700;
    margin: 0 0 20px;
    letter-spacing: 0.01em;
  }

  .glamhop-timeline {
    position: relative;
    padding-left: 28px;
  }

  .glamhop-timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 6px;
    bottom: 6px;
    width: 2px;
    background: var(--color-border, #e2e2e2);
  }

  .glamhop-timeline-item {
    position: relative;
    margin-bottom: 24px;
  }

  .glamhop-timeline-item:last-child {
    margin-bottom: 0;
  }

  .glamhop-timeline-dot {
    position: absolute;
    left: -24px;
    top: 4px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-border, #ccc);
    border: 2px solid var(--color-background, #fff);
    box-shadow: 0 0 0 2px var(--color-border, #ccc);
  }

  .glamhop-timeline-item.glamhop-timeline-item--active .glamhop-timeline-dot {
    background: var(--color-foreground, #1a1a1a);
    box-shadow: 0 0 0 2px var(--color-foreground, #1a1a1a);
  }

  .glamhop-timeline-status {
    font-size: 0.9rem;
    font-weight: 600;
    margin-bottom: 2px;
  }

  .glamhop-timeline-location {
    font-size: 0.82rem;
    color: var(--color-foreground-secondary, #888);
  }

  .glamhop-timeline-date {
    font-size: 0.78rem;
    color: var(--color-foreground-secondary, #aaa);
    margin-top: 2px;
  }

  .glamhop-no-tracking {
    text-align: center;
    padding: 32px 16px;
    color: var(--color-foreground-secondary, #888);
    font-size: 0.9rem;
  }

  @media (max-width: 480px) {
    .glamhop-tracking-wrapper {
      padding: 28px 12px 60px;
    }
    .glamhop-btn {
      padding: 13px 20px;
    }
  }
</style>

<script>
(function () {
  'use strict';

  const form = document.getElementById('glamhop-track-form');
  const submitBtn = document.getElementById('glamhop-submit-btn');
  const errorBox = document.getElementById('glamhop-error');
  const errorMsg = document.getElementById('glamhop-error-message');
  const resultBox = document.getElementById('glamhop-result');
  const orderSummary = document.getElementById('glamhop-order-summary');
  const timeline = document.getElementById('glamhop-timeline');

  function showError(message) {
    errorMsg.textContent = message;
    errorBox.hidden = false;
    resultBox.hidden = true;
  }

  function hideError() {
    errorBox.hidden = true;
  }

  function setLoading(isLoading) {
    submitBtn.disabled = isLoading;
    submitBtn.classList.toggle('glamhop-btn--loading', isLoading);
  }

  function formatDate(dateStr) {
    if (!dateStr) return '';
    try {
      return new Date(dateStr).toLocaleString('en-IN', {
        day: 'numeric', month: 'short', year: 'numeric',
        hour: '2-digit', minute: '2-digit'
      });
    } catch {
      return dateStr;
    }
  }

  function renderOrderSummary(data) {
    orderSummary.innerHTML = `
      <div style="display:flex;flex-wrap:wrap;gap:12px 24px;">
        <div><strong>Order</strong><br>${data.order_name || '—'}</div>
        <div><strong>Status</strong><br>${data.fulfillment_status || 'Unfulfilled'}</div>
        <div><strong>AWB</strong><br>${data.awb || '—'}</div>
        <div><strong>Courier</strong><br>${data.courier || '—'}</div>
      </div>
    `;
  }

  function renderTimeline(events) {
    if (!events || events.length === 0) {
      timeline.innerHTML = '<div class="glamhop-no-tracking">No tracking events available yet. Please check back after your order has been shipped.</div>';
      return;
    }

    timeline.innerHTML = events.map((event, index) => `
      <div class="glamhop-timeline-item ${index === 0 ? 'glamhop-timeline-item--active' : ''}">
        <div class="glamhop-timeline-dot"></div>
        <div class="glamhop-timeline-status">${event.status || '—'}</div>
        ${event.location ? `<div class="glamhop-timeline-location">${event.location}</div>` : ''}
        <div class="glamhop-timeline-date">${formatDate(event.date)}</div>
      </div>
    `).join('');
  }

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    hideError();
    resultBox.hidden = true;

    const orderNumber = document.getElementById('glamhop-order-number').value.trim();
    const email = document.getElementById('glamhop-email').value.trim();

    if (!orderNumber) {
      return showError('Please enter your order number.');
    }
    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      return showError('Please enter a valid email address.');
    }

    setLoading(true);

    try {
      // /apps/tracking/track is proxied by Shopify App Proxy → api/track.js
      const params = new URLSearchParams({ order_number: orderNumber, email });
      const response = await fetch(`/apps/tracking/track?${params.toString()}`, {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
      });

      const data = await response.json();

      if (!response.ok || data.error) {
        return showError(data.error || 'Something went wrong. Please try again.');
      }

      renderOrderSummary(data);
      renderTimeline(data.timeline);
      resultBox.hidden = false;

    } catch (err) {
      console.error('[glamhop-tracking] fetch error:', err);
      showError('Unable to connect. Please check your internet connection and try again.');
    } finally {
      setLoading(false);
    }
  });

})();
</script>

