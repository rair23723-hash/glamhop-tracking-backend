{
  "version": 2,
  "functions": {
    "api/**/*.js": {
      "includeFiles": "templates/**"
    }
  },
  "rewrites": [
    {
      "source": "/track",
      "destination": "/api/track"
    },
    {
      "source": "/api/track",
      "destination": "/api/track"
    },
    {
      "source": "/",
      "destination": "/api/index"
    },
    {
      "source": "/api",
      "destination": "/api/index"
    }
  ]
}
